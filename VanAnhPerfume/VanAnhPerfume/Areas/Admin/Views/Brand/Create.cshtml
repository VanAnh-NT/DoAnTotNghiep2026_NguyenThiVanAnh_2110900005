@model VanAnhPerfume.Models.Entities.Brand
@{
    Layout = "_AdminLayout";
    var isEdit = Model.BrandId > 0;
}
<h4>@(isEdit ? "Sửa thương hiệu" : "Thêm thương hiệu")</h4>
<form asp-action="Save" method="post" enctype="multipart/form-data" class="card p-3">
    <input type="hidden" asp-for="BrandId" />
    <div class="row g-3">
        <div class="col-md-6"><label>Tên thương hiệu</label><input asp-for="Name" class="form-control" required /></div>
        <div class="col-md-6"><label>Slug</label><input asp-for="Slug" class="form-control" /></div>
        <div class="col-md-3"><label>Quốc gia xuất xứ</label><input asp-for="CountryOfOrigin" class="form-control" /></div>
        <div class="col-md-3"><label>Website</label><input asp-for="Website" class="form-control" placeholder="https://..." /></div>
        <div class="col-md-3"><label>Thứ tự hiển thị</label><input asp-for="SortOrder" class="form-control" type="number" /></div>
        <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Active</label></div></div>
        <div class="col-md-6">
            <label>Logo (max 500KB)</label>
            <input type="file" name="logoFile" class="form-control" accept="image/*" />
            <input asp-for="LogoUrl" class="form-control mt-2" placeholder="Hoặc dán URL logo" />
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl ?? Model.Logo)){<img src="@(Model.LogoUrl ?? Model.Logo)" class="mt-2" width="72" height="72" style="border-radius:50%;object-fit:cover;" />}
        </div>
        <div class="col-md-6">
            <label>Banner</label>
            <input type="file" name="bannerFile" class="form-control" accept="image/*" />
            <input asp-for="BannerUrl" class="form-control mt-2" placeholder="Hoặc dán URL banner" />
            @if (!string.IsNullOrWhiteSpace(Model.BannerUrl)){<img src="@Model.BannerUrl" class="mt-2 img-fluid" style="max-height:80px;object-fit:cover;" />}
        </div>
        <div class="col-12">
            <label>Mô tả</label>
            <textarea asp-for="Description" id="brandDesc" class="form-control" rows="6"></textarea>
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary">Lưu</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</form>
@section Scripts{
<script src="https://cdn.jsdelivr.net/npm/tinymce@6.8.3/tinymce.min.js" referrerpolicy="origin"></script>
<script>
if (window.tinymce) {
    tinymce.init({selector:'#brandDesc',height:260,menubar:false,plugins:'lists link table',toolbar:'undo redo | bold italic | bullist numlist | link table'});
}
</script>
}
