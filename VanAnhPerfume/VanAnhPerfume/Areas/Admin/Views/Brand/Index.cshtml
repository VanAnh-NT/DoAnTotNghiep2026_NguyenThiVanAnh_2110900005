@model IEnumerable<VanAnhPerfume.Models.Entities.Brand>
@{
    Layout = "_AdminLayout";
    var productCounts = ViewBag.ProductCounts as Dictionary<int, int> ?? new();
}
<h4>Quản lý thương hiệu</h4>
@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <form method="get" class="d-flex flex-wrap align-items-center admin-filter-toolbar flex-grow-1">
        <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="Tìm thương hiệu" />
        <select name="isActive" class="form-select">
            <option value="">Tất cả trạng thái</option>
            <option value="true" selected="@(ViewBag.IsActive == true)">Active</option>
            <option value="false" selected="@(ViewBag.IsActive == false)">Inactive</option>
        </select>
        <select name="sort" class="form-select">
            <option value="">Mới nhất</option>
            <option value="name_asc" selected="@(ViewBag.Sort=="name_asc")">Tên A-Z</option>
            <option value="products_desc" selected="@(ViewBag.Sort=="products_desc")">Số sản phẩm</option>
        </select>
        <button type="submit" class="btn btn-secondary-lux">Lọc</button>
    </form>
    <a asp-action="Create" class="btn btn-primary">Thêm thương hiệu</a>
</div>
@if (Model.Any())
{
<div class="table-responsive">
    <table class="table table-lux align-middle">
        <thead><tr><th>Logo</th><th>Tên</th><th>Slug</th><th>Số SP</th><th>Quốc gia</th><th>Trạng thái</th><th>Action</th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><img src="@(item.LogoUrl ?? item.Logo ?? "/images/brand-placeholder.svg")" width="44" height="44" style="border-radius:50%;object-fit:cover;" /></td>
                <td>@item.Name</td>
                <td>@item.Slug</td>
                <td>@productCounts.GetValueOrDefault(item.BrandId)</td>
                <td>@(item.CountryOfOrigin ?? item.Country)</td>
                <td><span class="badge @(item.IsActive?"bg-success":"bg-secondary")">@(item.IsActive?"Active":"Inactive")</span></td>
                <td class="d-flex gap-1">
                    <a asp-action="Create" asp-route-id="@item.BrandId" class="btn btn-sm btn-outline-dark">Sửa</a>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@item.BrandId" />
                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa thương hiệu này?')">Xóa</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<nav><ul class="pagination">@for (var i = 1; i <= (int)ViewBag.TotalPages; i++){<li class="page-item @(i == (int)ViewBag.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-q="@ViewBag.Query" asp-route-isActive="@ViewBag.IsActive" asp-route-sort="@ViewBag.Sort" asp-route-page="@i">@i</a></li>}</ul></nav>
}
else
{
    <partial name="_AdminEmptyList" />
}
