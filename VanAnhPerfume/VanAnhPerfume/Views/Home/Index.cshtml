@foreach (var block in brandShowcases)
{
    <section class="product-banner section-block pt-0">
        <div class="site-container">
            <div class="widget-header">
                <div class="widget-title">Nước hoa @block.BrandName</div>

                <a href="/Home/Brand/@Uri.EscapeDataString(block.BrandSlug)" class="btn btn-secondary-lux py-2 px-3">
                    Xem tất cả
                </a>
            </div>

            <div class="widget-content">
                <div class="banner-featured">
                    <img src="@block.BannerImageUrl"
                         alt="@block.BrandName"
                         onerror="this.onerror=null;this.src='@heroFallback';" />
                </div>

                <div class="list-product">
                    @foreach (var item in block.Products)
                    {
                        <article class="product-item-mini">
                            <a href="/Product/Detail/@item.ProductId" class="product-thumbnail product-thumb">
                                <img class="product-thumb-main" src="@item.ImageUrl" alt="@item.ProductName" />
                                <img class="product-thumb-hover" src="@(item.HoverImageUrl ?? item.ImageUrl)" alt="@item.ProductName" />
                            </a>

                            <h3 class="product-title">
                                <a href="/Product/Detail/@item.ProductId">@item.ProductName</a>
                            </h3>

                            <span class="product-price">@item.FormattedPrice</span>
                        </article>
                    }
                </div>
            </div>
        </div>
    </section>
}

