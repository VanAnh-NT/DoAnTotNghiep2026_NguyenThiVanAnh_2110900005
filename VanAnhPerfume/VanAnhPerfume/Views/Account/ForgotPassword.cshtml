@model VanAnhPerfume.Models.ViewModels.ForgotPasswordVM
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Quên mật khẩu";
}
<h2 class="auth-subheading">Quên mật khẩu</h2>
<form asp-action="ForgotPassword" method="post">
    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" autocomplete="email" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>
    <button type="submit" class="auth-btn-primary mb-3">Gửi link đặt lại mật khẩu</button>
</form>
<div class="auth-links small">
    <p class="mb-0"><a asp-action="Login" class="auth-link-muted">Quay lại đăng nhập</a></p>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
