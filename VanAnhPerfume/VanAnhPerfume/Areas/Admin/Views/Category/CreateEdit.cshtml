@model VanAnhPerfume.Models.Entities.Category
@{
    Layout = "_AdminLayout";
    var isEdit = Model.CategoryId > 0;
    var parents = ViewBag.Parents as List<VanAnhPerfume.Models.Entities.Category> ?? [];
}
<h4>@(isEdit ? "Sửa danh mục" : "Thêm danh mục")</h4>
<form asp-action="Save" method="post" enctype="multipart/form-data" class="card p-3">
    <input type="hidden" asp-for="CategoryId" />
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Tên danh mục *</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Slug</label>
            <input asp-for="Slug" class="form-control" placeholder="auto nếu trống" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Danh mục cha</label>
            <select asp-for="ParentId" class="form-select">
                <option value="">(Không có)</option>
                @foreach (var p in parents)
                {
                    <option value="@p.CategoryId" selected="@(Model.ParentId == p.CategoryId)">@p.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Thứ tự</label>
            <input asp-for="SortOrder" class="form-control" type="number" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>
        <div class="col-md-8">
            <label class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>

        <div class="col-md-6">
            <label class="form-label">Ảnh file</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Hoặc URL ảnh</label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <div class="col-12">
                <div class="small text-muted mb-1">Ảnh hiện tại</div>
                <img src="@Model.ImageUrl" style="max-height:120px;object-fit:cover;border-radius:8px" />
            </div>
        }

        <div class="col-12 d-flex gap-2 mt-2">
            <button class="btn btn-primary" type="submit">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </div>
</form>

