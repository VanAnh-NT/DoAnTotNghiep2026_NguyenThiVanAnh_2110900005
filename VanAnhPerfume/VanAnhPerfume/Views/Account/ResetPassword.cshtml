@model VanAnhPerfume.Models.ViewModels.ResetPasswordVM
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Đặt lại mật khẩu";
}
<h2 class="auth-subheading">Đặt lại mật khẩu</h2>
<form asp-action="ResetPassword" method="post">
    <input asp-for="Token" type="hidden" />
    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label">Mật khẩu mới</label>
        <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="NewPassword" class="text-danger small"></span>
    </div>
    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>
    <button type="submit" class="auth-btn-primary mb-3">Cập nhật mật khẩu</button>
</form>
<div class="auth-links small">
    <p class="mb-0"><a asp-action="Login" class="auth-link-muted">Quay lại đăng nhập</a></p>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
