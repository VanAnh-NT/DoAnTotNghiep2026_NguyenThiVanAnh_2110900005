@model IEnumerable<VanAnhPerfume.Models.ViewModels.ProductInventoryRowVM>
@{
    Layout = "_AdminLayout";
    var product = ViewBag.Product as VanAnhPerfume.Models.Entities.Product;
    var logs = ViewBag.Logs as List<VanAnhPerfume.Models.Entities.InventoryLog> ?? [];
}
<h4>Tồn kho sản phẩm: @product?.Name</h4>
<a asp-action="Index" class="btn btn-light mb-3">← Quay lại danh sách</a>
<table class="table table-lux">
    <thead><tr><th>Biến thể</th><th>SKU</th><th>Có thể bán</th><th>Đã đặt</th><th>Đã bán</th><th>Ngưỡng</th><th>Hành động</th></tr></thead>
    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.VariantLabel</td>
            <td>@r.Sku</td>
            <td>@r.Sellable</td>
            <td>@r.QuantityReserved</td>
            <td>@r.QuantitySold</td>
            <td>@r.LowStockThreshold</td>
            <td class="d-flex gap-1">
                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#import-@r.VariantId">Nhập kho</button>
                <button class="btn btn-sm btn-outline-dark" data-bs-toggle="modal" data-bs-target="#adjust-@r.VariantId">Điều chỉnh</button>
            </td>
        </tr>

        <div class="modal fade" id="import-@r.VariantId" tabindex="-1">
            <div class="modal-dialog"><div class="modal-content"><form asp-action="ImportStock" method="post">
                <div class="modal-header"><h6>Nhập kho @r.Sku</h6></div>
                <div class="modal-body">
                    <input type="hidden" name="productId" value="@product?.ProductId" />
                    <input type="hidden" name="variantId" value="@r.VariantId" />
                    <label>Số lượng</label><input name="quantity" type="number" class="form-control" min="1" required />
                    <label class="mt-2">Ghi chú</label><input name="note" class="form-control" />
                </div>
                <div class="modal-footer"><button class="btn btn-primary">Lưu</button></div>
            </form></div></div>
        </div>

        <div class="modal fade" id="adjust-@r.VariantId" tabindex="-1">
            <div class="modal-dialog"><div class="modal-content"><form asp-action="AdjustStock" method="post">
                <div class="modal-header"><h6>Điều chỉnh @r.Sku</h6></div>
                <div class="modal-body">
                    <input type="hidden" name="productId" value="@product?.ProductId" />
                    <input type="hidden" name="variantId" value="@r.VariantId" />
                    <label>Số lượng mới</label><input name="newQuantity" type="number" class="form-control" min="0" value="@r.QuantityAvailable" required />
                    <label class="mt-2">Lý do *</label><input name="reason" class="form-control" required />
                </div>
                <div class="modal-footer"><button class="btn btn-dark">Cập nhật</button></div>
            </form></div></div>
        </div>
    }
    </tbody>
</table>

<h5>Lịch sử nhập/xuất</h5>
<table class="table table-sm">
    <thead><tr><th>Thời gian</th><th>VariantId</th><th>Loại</th><th>Thay đổi</th><th>Tồn sau</th><th>Ghi chú</th><th>Người thực hiện</th></tr></thead>
    <tbody>
    @foreach (var log in logs)
    {
        <tr>
            <td>@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@log.VariantId</td>
            <td>@(log.ChangeType ?? log.ActionType)</td>
            <td>@(log.QuantityChange != 0 ? log.QuantityChange : log.QuantityDelta)</td>
            <td>@(log.QuantityAfter != 0 ? log.QuantityAfter : log.StockAfter)</td>
            <td>@log.Note</td>
            <td>@log.CreatedBy</td>
        </tr>
    }
    </tbody>
</table>
