@model VanAnhPerfume.Models.Entities.Order
@{
    ViewData["Title"] = $"Đơn hàng {(Model.OrderCode ?? $"#{Model.OrderId}")}";
    var payment = ViewBag.Payment as VanAnhPerfume.Models.Entities.Payment;
    var timeline = ViewBag.Timeline as List<VanAnhPerfume.Models.Entities.OrderStatusLog> ?? [];
    var nextStatuses = ViewBag.NextStatuses as List<string> ?? [];
    var subtotal = Model.SubTotal > 0 ? Model.SubTotal : Model.OrderDetails.Sum(x => x.Price * x.Quantity);
    string OBadge(string? s) => s switch
    {
        "Pending" => "bg-warning text-dark",
        "Processing" => "bg-primary",
        "Shipped" => "bg-info text-dark",
        "Delivered" => "bg-success",
        "Completed" => "bg-dark",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };
    string PBadge(string? s) => s switch
    {
        "Paid" => "bg-success",
        "Pending" => "bg-secondary",
        "Failed" => "bg-danger",
        "Refunded" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-1">Đơn hàng @(Model.OrderCode ?? $"#{Model.OrderId}")</h4>
        <div class="text-muted">Ngày đặt: @Model.OrderDate?.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
    <div class="d-flex gap-2">
        <span class="badge @OBadge(Model.Status)">@Model.Status</span>
        <span class="badge @PBadge(Model.PaymentStatus)">@Model.PaymentStatus</span>
        <a asp-action="Invoice" asp-route-id="@Model.OrderId" class="btn btn-outline-dark btn-sm">In hóa đơn</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6"><div class="card shadow-sm"><div class="card-header bg-white fw-semibold">Thông tin khách hàng</div><div class="card-body">
        <div><strong>@Model.FullName</strong></div>
        <div>Email: @(Model.CustomerEmail ?? Model.User?.Email)</div>
        <div>Phone: @Model.Phone</div>
        <div>Địa chỉ: @Model.Address</div>
        <div>@Model.ShippingDistrict @Model.ShippingProvince</div>
    </div></div></div>
    <div class="col-md-6"><div class="card shadow-sm"><div class="card-header bg-white fw-semibold">Thông tin thanh toán</div><div class="card-body">
        <div>Phương thức: <strong>@(payment?.PaymentMethod ?? "COD")</strong></div>
        <div>Trạng thái: <span class="badge @PBadge(payment?.Status ?? Model.PaymentStatus)">@(payment?.Status ?? Model.PaymentStatus)</span></div>
        <div>TransactionId: @(payment?.TransactionId ?? "-")</div>
        <div>PaidAt: @(payment?.PaidAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
    </div></div></div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Sản phẩm đặt hàng</div>
    <div class="table-responsive">
        <table class="table table-lux align-middle mb-0">
            <thead><tr><th>Ảnh</th><th>Tên SP - Biến thể</th><th>SKU</th><th>Đơn giá</th><th>SL</th><th>Thành tiền</th></tr></thead>
            <tbody>
            @foreach (var item in Model.OrderDetails)
            {
                <tr>
                    <td><img src="@(item.Variant?.Product?.MainImage ?? "/images/default-perfume.jpg")" style="width:56px;height:56px;object-fit:cover;border-radius:6px;" /></td>
                    <td>@(item.ProductName ?? item.Variant?.Product?.Name)<br/><small>@(item.VariantName ?? item.Variant?.Size)</small></td>
                    <td>@(item.Sku ?? item.Variant?.Sku)</td>
                    <td>@item.Price.ToString("N0") ₫</td>
                    <td>@item.Quantity</td>
                    <td class="fw-semibold">@((item.Price * item.Quantity).ToString("N0")) ₫</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="card-body text-end">
        <div>Subtotal: @subtotal.ToString("N0") ₫</div>
        <div>Giảm giá (@Model.CouponCode): -@Model.DiscountAmount.ToString("N0") ₫</div>
        <div>Ship: @Model.ShippingFee.ToString("N0") ₫</div>
        <h5 class="mt-2">Tổng tiền: @Model.TotalAmount.ToString("N0") ₫</h5>
    </div>
</div>

<div class="card shadow-sm mb-3 border-primary">
    <div class="card-header bg-primary text-white fw-semibold">Cập nhật trạng thái</div>
    <div class="card-body">
        @if (TempData["Error"] != null){<div class="alert alert-danger">@TempData["Error"]</div>}
        <form asp-action="UpdateStatus" method="post" class="row g-2 align-items-end">
            <input type="hidden" name="orderId" value="@Model.OrderId" />
            <div class="col-md-4">
                <label>Current status</label>
                <div><span class="badge @OBadge(Model.Status)">@Model.Status</span></div>
            </div>
            <div class="col-md-4">
                <label>Chuyển trạng thái</label>
                <select name="newStatus" class="form-select" @(nextStatuses.Count==0?"disabled":"")>
                    @foreach (var s in nextStatuses){<option value="@s">@s</option>}
                </select>
            </div>
            <div class="col-md-4">
                <label>Ghi chú admin</label>
                <input class="form-control" name="adminNote" value="@Model.AdminNote" />
            </div>
            <div class="col-md-3"><button class="btn btn-primary w-100" @(nextStatuses.Count==0?"disabled":"")>Cập nhật</button></div>
        </form>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Timeline trạng thái</div>
    <div class="card-body">
        @if (!timeline.Any()){<div class="text-muted">Chưa có log.</div>}
        else
        {
            <ul class="list-unstyled mb-0">
                @foreach (var log in timeline)
                {
                    <li class="mb-2"><span class="me-2">●</span><strong>@log.NewStatus</strong> - @log.Note <span class="text-muted">(@log.ChangedBy - @log.CreatedAt.ToString("dd/MM/yyyy HH:mm"))</span></li>
                }
            </ul>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white fw-semibold">Ghi chú nội bộ</div>
    <div class="card-body">
        <textarea id="adminNoteBox" class="form-control" rows="4">@Model.AdminNote</textarea>
        <button id="saveNoteBtn" class="btn btn-outline-dark mt-2">Save note</button>
    </div>
</div>

@section Scripts{
<script>
document.getElementById('saveNoteBtn')?.addEventListener('click', async () => {
  const adminNote = document.getElementById('adminNoteBox').value;
  const form = new URLSearchParams();
  form.append('orderId', '@Model.OrderId');
  form.append('adminNote', adminNote);
  await fetch('/Admin/Order/SaveAdminNote', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: form });
});
</script>
}
