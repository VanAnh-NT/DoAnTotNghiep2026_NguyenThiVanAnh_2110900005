@model VanAnhPerfume.Models.ViewModels.ChangePasswordVM
@{
    ViewData["Title"] = "Đổi mật khẩu";
}
<section class="section-block pt-4">
<div class="site-container">
    <div class="row g-4">
        <div class="col-12 col-md-4">
            <partial name="_AccountNav" />
        </div>
        <div class="col-12 col-md-8">
            <h3 class="mb-3">Đổi mật khẩu</h3>
            @if (ViewBag.Message != null) { <div class="alert alert-success">@ViewBag.Message</div> }
            <form method="post" class="border p-3">
                <div class="mb-3">
                    <label>Mật khẩu hiện tại</label>
                    <input asp-for="CurrentPassword" type="password" class="form-control rounded-0" />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label>Mật khẩu mới</label>
                    <input asp-for="NewPassword" type="password" class="form-control rounded-0" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label>Xác nhận mật khẩu mới</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control rounded-0" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <button class="btn btn-primary-lux">Cập nhật</button>
            </form>
        </div>
    </div>
</div>
</section>
