@model VanAnhPerfume.Models.ViewModels.PromotionFormVm
@{
    Layout = "_AdminLayout";
    var isActive = Model.IsActive;
    var isEdit = Model.PromoId > 0;
}
<h4>@(isEdit ? "Sửa chương trình khuyến mãi" : "Thêm chương trình khuyến mãi")</h4>
<form asp-action="Save" method="post" class="card p-3">
    <div asp-validation-summary="All" class="text-danger mb-2"></div>
    <div class="row g-3">
        <input type="hidden" asp-for="PromoId" />
        <div class="col-md-4">
            <label class="form-label" asp-for="Name"></label>
            <input asp-for="Name" class="form-control" autocomplete="off" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="col-md-2">
            <label class="form-label" asp-for="DiscountPercent"></label>
            <input asp-for="DiscountPercent" type="number" min="1" max="90" class="form-control" />
            <span asp-validation-for="DiscountPercent" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label" asp-for="StartDate"></label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label" asp-for="EndDate"></label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger small"></span>
        </div>

        <div class="col-md-3">
            <label class="form-label" asp-for="MinOrderValue"></label>
            <input asp-for="MinOrderValue" type="number" min="0" step="0.01" class="form-control" />
            <span asp-validation-for="MinOrderValue" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label" asp-for="ApplicableCategoryIds"></label>
            <input asp-for="ApplicableCategoryIds" class="form-control" placeholder="vd: 1,2,3" />
        </div>
        <div class="col-md-3">
            <label class="form-label" asp-for="ApplicableProductIds"></label>
            <input asp-for="ApplicableProductIds" class="form-control" placeholder="vd: 10,20" />
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <div class="form-check">
                <input type="hidden" name="IsActive" value="false" />
                <input type="checkbox" name="IsActive" value="true" class="form-check-input" checked="@(isActive ? "checked" : null)" />
                <label class="form-check-label">Kích hoạt</label>
            </div>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="AutoApply" class="form-check-input" type="checkbox" />
                <label class="form-check-label" asp-for="AutoApply"></label>
            </div>
        </div>

        <div class="col-12 d-flex gap-2 mt-2">
            <button class="btn btn-primary" type="submit">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
