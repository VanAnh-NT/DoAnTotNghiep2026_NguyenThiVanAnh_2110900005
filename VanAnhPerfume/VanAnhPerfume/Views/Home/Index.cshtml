    <div class="site-container">
        <div class="row g-4">
            <div class="col-12 col-md-3">
                <h3 class="h6 home-trust-strip__title"><i class="bi bi-patch-check me-1"></i> Hàng Chính Hãng</h3>
                <p class="text-muted home-trust-strip__text">Nguồn gốc minh bạch, bảo hành chuẩn hãng.</p>
            </div>
            <div class="col-12 col-md-3">
                <h3 class="h6 home-trust-strip__title"><i class="bi bi-truck me-1"></i> Freeship 500K+</h3>
                <p class="text-muted home-trust-strip__text">Giao nhanh toàn quốc, đóng gói premium.</p>
            </div>
            <div class="col-12 col-md-3">
                <h3 class="h6 home-trust-strip__title"><i class="bi bi-arrow-repeat me-1"></i> Đổi Trả 7 Ngày</h3>
                <p class="text-muted home-trust-strip__text">Đảm bảo trải nghiệm mua sắm an tâm.</p>
            </div>
            <div class="col-12 col-md-3">
                <h3 class="h6 home-trust-strip__title"><i class="bi bi-chat-dots me-1"></i> Tư Vấn 24/7</h3>
                <p class="text-muted home-trust-strip__text">Đội ngũ chuyên gia mùi hương đồng hành.</p>
            </div>
        </div>
    </div>
</section>
@if (midBanners.Any())
{
<section class="section-block pt-0">
    <div class="site-container">
        <div class="row g-4">
            @foreach (var b in midBanners)
            {
                <div class="col-12 col-md-6">
                    <a href="@(string.IsNullOrWhiteSpace(b.LinkUrl)?"/Product":b.LinkUrl)" class="d-block position-relative">
                        <img src="@b.ImageUrl"
                             srcset="@(string.IsNullOrWhiteSpace(b.MobileImageUrl) ? b.ImageUrl : $"{b.MobileImageUrl} 768w, {b.ImageUrl} 1920w")"
                             style="width:100%;aspect-ratio:16/7;object-fit:cover;" />
                        <div class="position-absolute bottom-0 start-0 p-3" style="color:@(b.TextColor ?? "#fff")">@b.Title</div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>
}

<section class="section-block">
    <div class="site-container">
        <h2 class="text-center mb-4">TẠP CHÍ NƯỚC HOA</h2>

        <div class="row g-4">
            @foreach (var post in posts)
            {
                var title = DecodeHtmlText(post.Title);
                var excerpt = BuildExcerpt(post.Excerpt, post.Content, 120);
                var imageUrl = post.ThumbnailUrl ?? post.Image ?? "/images/default-perfume.jpg";

                <div class="col-12 col-md-4">
                    <a href="/Home/BlogDetail/@post.NewsId"
                           class="product-card home-blog-card d-block h-100 text-decoration-none text-dark"
                           title="@title">
                        <img src="@imageUrl"
                             alt="@title"
                             style="width:100%;aspect-ratio:16/9;object-fit:cover;" />

                        <div class="p-3">
                            <div class="label-uppercase text-muted mb-1">
                                Editorial
                            </div>

                            <h3 class="h6 mb-2 home-blog-card__title">
                                @title
                            </h3>

                            <p class="text-muted mb-0">
                                @excerpt
                            </p>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        new Swiper('.hero-swiper', {
            loop: true,
            autoplay: { delay: 5000 },
            pagination: { el: '.hero-swiper .swiper-pagination', clickable: true }
        });
    </script>
}