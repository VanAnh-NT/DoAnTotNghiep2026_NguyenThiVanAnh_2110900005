@model VanAnhPerfume.Models.ViewModels.PaymentVM
@{
    var orderId = Model.OrderId;
    var amount = Model.Amount;
}

<div class="container mt-5 text-center">
    <h2 class="fw-bold text-success">ĐẶT HÀNG THÀNH CÔNG</h2>
    <p>Mã đơn hàng của bạn là: <strong>#@orderId</strong></p>
    <p>Phương thức thanh toán: <strong>@Model.PaymentMethod</strong></p>
    <p>Trạng thái thanh toán: <strong>@Model.PaymentStatus</strong></p>

    @if (!string.IsNullOrWhiteSpace(Model.CustomerEmail))
    {
        <p class="text-muted mb-0">Email <strong>@Model.CustomerEmail</strong> đã nhận được thông tin và đơn hàng nhé.</p>
    }
    else
    {
        <p class="text-muted mb-0">Cảm ơn bạn! Chúng tôi đã ghi nhận đơn hàng.</p>
    }

    @if (string.Equals(Model.PaymentMethod, "VNPAY", StringComparison.OrdinalIgnoreCase) && !string.Equals(Model.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase))
    {
        <div class="mt-3">
            <form asp-action="CreateVnpayPayment" method="post">
                <input type="hidden" name="id" value="@orderId" />
                <button type="submit" class="btn btn-success">Thanh toán bằng VNPAY Sandbox</button>
            </form>
        </div>
    }
    else if (string.Equals(Model.PaymentMethod, "COD", StringComparison.OrdinalIgnoreCase))
    {
        <div class="alert alert-info d-inline-block rounded-0 mt-3">
            Đơn hàng sẽ được thanh toán khi giao hàng (COD).
        </div>
    }

    <div class="mt-4">
        <a href="/" class="btn btn-outline-dark rounded-0">Về trang chủ</a>
        <a href="/Account/OrderTracking/@orderId" class="btn btn-dark rounded-0">Chi tiết đơn hàng</a>
    </div>
</div>
