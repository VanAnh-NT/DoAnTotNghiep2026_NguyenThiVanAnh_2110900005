@model VanAnhPerfume.Models.ViewModels.PaymentVM
@{
    ViewData["Title"] = "Kết quả thanh toán";
    var isSuccess = string.Equals(Model.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase);
}
<div class="container py-5 text-center">
    <div class="display-4 mb-2">@(isSuccess ? "✓" : "✗")</div>
    <h3 class="mb-3 @(isSuccess ? "text-success" : "text-danger")">@(isSuccess ? "Đặt hàng thành công!" : "Thanh toán thất bại")</h3>
    <p class="lead">@Model.Message</p>
    <p>Mã đơn hàng: <strong>@(Model.OrderCode ?? $"ORD-{Model.OrderId}")</strong></p>
    <p>Số tiền: <strong>@Model.Amount.ToString("N0") ₫</strong></p>
    @if (isSuccess && !string.IsNullOrWhiteSpace(Model.CustomerEmail))
    {
        <p class="text-muted">Email <strong>@Model.CustomerEmail</strong> đã nhận được thông tin và đơn hàng nhé.</p>
    }
    @if (!isSuccess)
    {
        <p class="text-muted">Mã phản hồi: @Model.ResponseCode</p>
    }
    <div class="mt-3 d-flex flex-wrap justify-content-center gap-2">
        <a href="/Account/OrderTracking/@Model.OrderId" class="btn btn-dark">Chi tiết đơn hàng</a>
        <a href="/" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
        @if (!isSuccess)
        {
            <form asp-action="CreateVnpayPayment" method="post" class="d-inline">
                <input type="hidden" name="id" value="@Model.OrderId" />
                <button class="btn btn-success">Thử lại</button>
            </form>
            <form asp-action="CancelOrder" method="post" class="d-inline">
                <input type="hidden" name="id" value="@Model.OrderId" />
                <button class="btn btn-danger">Hủy đơn hàng</button>
            </form>
        }
    </div>
</div>
