@using System.Net
@using System.Text.RegularExpressions
@model IEnumerable<VanAnhPerfume.Models.ViewModels.ProductHomeVM>
@{
    ViewData["Title"] = "Luxury Perfume";
    // var homeCategories = ViewBag.HomeCategories as List<VanAnhPerfume.Models.Entities.Category> ?? [];
    // var categoryShowcases = ViewBag.CategoryShowcases as List<VanAnhPerfume.Models.ViewModels.HomeCategoryShowcaseVM> ?? [];
    var homeBrands = ViewBag.HomeBrands as List<VanAnhPerfume.Models.Entities.Brand> ?? [];
    var brandShowcases = ViewBag.BrandShowcases as List<VanAnhPerfume.Models.ViewModels.HomeBrandShowcaseVM> ?? [];
    var posts = ViewBag.LatestNews as List<VanAnhPerfume.Models.Entities.News> ?? [];
    var banners = ViewBag.Banners as List<VanAnhPerfume.Models.Entities.Banner> ?? [];
    var midBanners = ViewBag.MidBanners as List<VanAnhPerfume.Models.Entities.Banner> ?? [];
    const string heroFallback = "/images/hero-placeholder.svg";

    string DecodeHtmlText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var text = value;

        for (var i = 0; i < 3; i++)
        {
            var decoded = WebUtility.HtmlDecode(text);

            if (decoded == text)
            {
                break;
            }

            text = decoded;
        }

        return text;
    }

    string BuildExcerpt(string? excerpt, string? content, int length = 120)
    {
        var rawText = !string.IsNullOrWhiteSpace(excerpt)
            ? excerpt
            : Regex.Replace(content ?? string.Empty, "<.*?>", " ");

        rawText = DecodeHtmlText(rawText);
        rawText = Regex.Replace(rawText, "<.*?>", " ");
        rawText = Regex.Replace(rawText, @"\s+", " ").Trim();

        return rawText.Length > length ? rawText[..length] + "..." : rawText;
    }
}
<section class="home-slider py-3">
    <div class="container-fluid px-0">
        <div class="row g-0">
            <div class="col-12">
                <div class="swiper hero-swiper w-100">
                    <div class="swiper-wrapper">
                        @if (banners.Any())
                        {
                            @foreach (var banner in banners)
                            {
                                <div class="swiper-slide">
                                    <a href="@(string.IsNullOrWhiteSpace(banner.LinkUrl) ? "/Product" : banner.LinkUrl)" title="@banner.Title" class="d-block position-relative">
                                        <img src="@banner.ImageUrl"
                                             srcset="@(string.IsNullOrWhiteSpace(banner.MobileImageUrl) ? banner.ImageUrl : $"{banner.MobileImageUrl} 768w, {banner.ImageUrl} 1920w")"
                                             onerror="this.onerror=null;this.src='@heroFallback';"
                                             alt="@banner.Title"
                                             class="w-100 hero-banner-img" />
                                        <div class="position-absolute top-50 start-0 translate-middle-y p-4" style="color:@(banner.TextColor ?? "#fff");max-width:520px;">
                                            <h2 class="h4 mb-2">@banner.Title</h2>
                                            <p class="mb-2">@banner.SubTitle</p>
                                            @if (!string.IsNullOrWhiteSpace(banner.ButtonText)){<span class="btn btn-sm btn-light">@banner.ButtonText</span>}
                                        </div>
                                    </a>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="swiper-slide">
                                <a href="/Product" title="Banner">
                                    <img src="https://tprofumo.com/wp-content/uploads/2023/04/banner_brand_image_tprofumo2.jpg"
                                         onerror="this.onerror=null;this.src='@heroFallback';"
                                         alt="Banner"
                                         class="w-100 hero-banner-img" />
                                </a>
                            </div>
                        }
                    </div>
                    <div class="swiper-pagination"></div>
                </div>
            </div>
        </div>
    </div>
</section>

