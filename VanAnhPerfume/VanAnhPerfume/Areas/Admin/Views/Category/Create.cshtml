@model VanAnhPerfume.Models.Entities.Category
@{
    Layout = "_AdminLayout";
    var parents = ViewBag.Parents as List<VanAnhPerfume.Models.Entities.Category> ?? [];
}
<h4>Thêm danh mục</h4>
<form method="post" class="card p-3">
    <div class="row g-3">
        <div class="col-md-6">
            <label>Tên danh mục</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-6">
            <label>Danh mục cha</label>
            <select asp-for="ParentId" class="form-select">
                <option value="">-- Không có --</option>
                @foreach (var p in parents)
                {
                    <option value="@p.CategoryId">@p.Name</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label>Slug</label>
            <input asp-for="Slug" class="form-control" />
        </div>
        <div class="col-md-6">
            <label>Meta title</label>
            <input asp-for="MetaTitle" class="form-control" />
        </div>
        <div class="col-12">
            <label>Meta description</label>
            <textarea asp-for="MetaDescription" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-4">
            <label class="form-label">Trạng thái</label>
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary">Lưu</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</form>
