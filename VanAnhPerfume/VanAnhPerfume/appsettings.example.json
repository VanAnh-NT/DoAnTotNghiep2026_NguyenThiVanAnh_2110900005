{
  "App": {
    "PublicBaseUrl": "https://localhost:3000"
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER_NAME;Database=VanAnhPerfume;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },

  "Seed": {
    "EnableOnStartup": false,
    "ResetOnStartup": false
  },

  "Vnpay": {
    "TmnCode": "YOUR_VNPAY_SANDBOX_TMN_CODE",
    "HashSecret": "YOUR_VNPAY_SANDBOX_HASH_SECRET",
    "PaymentUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "ReturnUrl": "https://localhost:3000/Checkout/VnpayReturn",
    "IpnUrl": "https://localhost:3000/Checkout/VnpayIpn"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}