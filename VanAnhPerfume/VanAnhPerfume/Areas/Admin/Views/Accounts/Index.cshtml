@model VanAnhPerfume.Models.ViewModels.AdminAccountsIndexVm
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tài khoản & phân quyền";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h4 class="m-0">Tài khoản &amp; phân quyền</h4>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success rounded-0 mb-3">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger rounded-0 mb-3">@TempData["Error"]</div>
}

<p class="text-muted small mb-3">
    Nâng quyền khách hàng thành quản trị viên, hoặc hạ quyền quản trị xuống khách hàng. Bạn không thể hạ quyền chính mình hoặc xóa admin cuối cùng.
    Người được nâng quyền cần <strong>đăng xuất và đăng nhập lại</strong> để cookie có vai trò mới.
</p>

<div class="d-flex flex-wrap gap-2 mb-4">
    <span class="badge rounded-pill bg-dark px-3 py-2">Tổng: @Model.Stats.Total</span>
    <span class="badge rounded-pill bg-primary px-3 py-2">Quản trị: @Model.Stats.AdminCount</span>
    <span class="badge rounded-pill bg-secondary px-3 py-2">Khách hàng: @Model.Stats.CustomerCount</span>
</div>

<form method="get" class="d-flex flex-wrap align-items-center admin-filter-toolbar mb-3">
    <input id="accountsFilterQ" name="q" value="@Model.Q" class="form-control" placeholder="Tên, email, SĐT" />
    <select id="accountsFilterRole" name="role" class="form-select" aria-label="Vai trò">
        @foreach (var opt in new[] { ("all", "Tất cả"), ("admin", "Quản trị"), ("customer", "Khách hàng") })
        {
            if (Model.RoleFilter == opt.Item1)
            {<option value="@opt.Item1" selected>@opt.Item2</option>}
            else
            {<option value="@opt.Item1">@opt.Item2</option>}
        }
    </select>
    <button type="submit" class="btn btn-secondary-lux">Lọc</button>
</form>

@if (Model.Rows.Any())
{
<div class="table-responsive">
    <table class="table table-lux align-middle">
        <thead>
            <tr>
                <th>Họ tên</th>
                <th>Email</th>
                <th>SĐT</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th>Đăng ký</th>
                <th>Đăng nhập cuối</th>
                <th style="min-width:200px">Phân quyền</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            var isAdmin = string.Equals(row.RoleName, "Admin", StringComparison.OrdinalIgnoreCase);
            <tr>
                <td>@row.FullName</td>
                <td>@row.Email</td>
                <td>@(row.Phone ?? "—")</td>
                <td>
                    @if (isAdmin)
                    {<span class="badge bg-primary">Quản trị</span>}
                    else
                    {<span class="badge bg-secondary">Khách hàng</span>}
                </td>
                <td>
                    @if (row.IsActive)
                    {<span class="badge bg-success">Hoạt động</span>}
                    else
                    {<span class="badge bg-danger">Bị khóa</span>}
                </td>
                <td>@(row.CreatedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                <td>@(row.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                <td>
                    @if (!isAdmin)
                    {
                        if (row.IsActive)
                        {
                            <form asp-area="Admin" asp-controller="Accounts" asp-action="PromoteToAdmin" method="post" class="d-none role-action-form" id="role-form-promote-@row.UserId">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@row.UserId" />
                                <input type="hidden" name="q" value="@Model.Q" />
                                <input type="hidden" name="role" value="@Model.RoleFilter" />
                                <input type="hidden" name="page" value="@Model.Page" />
                            </form>
                            <button type="button" class="btn btn-sm btn-primary js-role-confirm"
                                    data-bs-toggle="modal" data-bs-target="#roleConfirmModal"
                                    data-action="promote"
                                    data-form-id="role-form-promote-@row.UserId"
                                    data-email="@row.Email">Nâng quyền Admin</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-secondary" disabled title="Tài khoản đang bị khóa">Nâng quyền Admin</button>
                        }
                    }
                    else if (row.UserId == Model.CurrentOperatorUserId)
                    {
                        <span class="text-muted small">Tài khoản của bạn</span>
                    }
                    else
                    {
                        <form asp-area="Admin" asp-controller="Accounts" asp-action="DemoteToCustomer" method="post" class="d-none role-action-form" id="role-form-demote-@row.UserId">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@row.UserId" />
                            <input type="hidden" name="q" value="@Model.Q" />
                            <input type="hidden" name="role" value="@Model.RoleFilter" />
                            <input type="hidden" name="page" value="@Model.Page" />
                        </form>
                        <button type="button" class="btn btn-sm btn-outline-danger js-role-confirm"
                                data-bs-toggle="modal" data-bs-target="#roleConfirmModal"
                                data-action="demote"
                                data-form-id="role-form-demote-@row.UserId"
                                data-email="@row.Email">Hạ quyền</button>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
}
else
{
    <partial name="_AdminEmptyList" />
}

@if (Model.Rows.Any() && Model.TotalPages > 1)
{
    <nav class="mt-3 d-flex flex-wrap align-items-center gap-2">
        <a class="btn btn-sm btn-outline-secondary @(Model.Page <= 1 ? "disabled" : null)"
           asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-q="@Model.Q" asp-route-role="@Model.RoleFilter">Trước</a>
        <span class="text-muted small">Trang @Model.Page / @Model.TotalPages</span>
        <a class="btn btn-sm btn-outline-secondary @(Model.Page >= Model.TotalPages ? "disabled" : null)"
           asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-q="@Model.Q"            asp-route-role="@Model.RoleFilter">Sau</a>
    </nav>
}

<div class="modal fade" id="roleConfirmModal" tabindex="-1" aria-labelledby="roleConfirmModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-0 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <div class="d-flex align-items-center gap-2">
                    <span class="rounded-circle d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary" id="roleConfirmIconWrap" style="width:40px;height:40px;">
                        <i class="bi bi-shield-check" id="roleConfirmIcon"></i>
                    </span>
                    <h5 class="modal-title mb-0" id="roleConfirmModalTitle">Xác nhận</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body pt-2 text-muted" id="roleConfirmModalBody"></div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary rounded-0" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary rounded-0" id="roleConfirmSubmitBtn">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const modalEl = document.getElementById('roleConfirmModal');
    const bodyEl = document.getElementById('roleConfirmModalBody');
    const titleEl = document.getElementById('roleConfirmModalTitle');
    const submitBtn = document.getElementById('roleConfirmSubmitBtn');
    const iconEl = document.getElementById('roleConfirmIcon');
    const iconWrap = document.getElementById('roleConfirmIconWrap');
    let pendingFormId = '';

    function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
    }

    modalEl.addEventListener('show.bs.modal', function (event) {
        const btn = event.relatedTarget;
        if (!btn || !btn.classList.contains('js-role-confirm')) return;

        const action = btn.getAttribute('data-action');
        const email = btn.getAttribute('data-email') || '';
        pendingFormId = btn.getAttribute('data-form-id') || '';

        if (action === 'promote') {
            titleEl.textContent = 'Cấp quyền quản trị';
            bodyEl.innerHTML =
                '<p class="mb-2">Bạn sắp cấp quyền <strong>Quản trị viên</strong> cho tài khoản:</p>' +
                '<p class="mb-3 fw-semibold text-dark">' + escapeHtml(email) + '</p>' +
                '<p class="small mb-0">Người này cần <strong>đăng xuất và đăng nhập lại</strong> để cookie có vai trò mới và truy cập được khu vực admin.</p>';
            iconEl.className = 'bi bi-shield-check';
            iconWrap.className = 'rounded-circle d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary';
            submitBtn.className = 'btn btn-primary rounded-0';
            submitBtn.textContent = 'Cấp quyền';
        } else {
            titleEl.textContent = 'Hạ quyền xuống khách hàng';
            bodyEl.innerHTML =
                '<p class="mb-2">Bạn sắp hạ quyền tài khoản sau xuống <strong>Khách hàng</strong>:</p>' +
                '<p class="mb-0 fw-semibold text-dark">' + escapeHtml(email) + '</p>' +
                '<p class="small mt-3 mb-0 text-danger">Họ sẽ không còn truy cập trang quản trị sau khi phiên đăng nhập được làm mới.</p>';
            iconEl.className = 'bi bi-person-dash';
            iconWrap.className = 'rounded-circle d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger';
            submitBtn.className = 'btn btn-danger rounded-0';
            submitBtn.textContent = 'Hạ quyền';
        }
    });

    submitBtn.addEventListener('click', function () {
        const form = pendingFormId ? document.getElementById(pendingFormId) : null;
        if (form) {
            form.submit();
        }
        const inst = bootstrap.Modal.getInstance(modalEl);
        if (inst) inst.hide();
    });
})();
</script>
}
